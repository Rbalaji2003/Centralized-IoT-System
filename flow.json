    {
        "id": "5caa4fb7f61919c3",
        "type": "function",
        "z": "ddbcc77b5a1c5a84",
        "name": "Extract Sensor Values",
        "func": "// Make sure msg.payload is an object, not a string\nlet data = msg.payload;\n\n// If it’s a string, parse it first\nif (typeof data === \"string\") {\n    data = JSON.parse(data);\n}\n\nreturn [\n    { payload: data.temperature }, // output 1 → temperature gauge\n    { payload: data.humidity },    // output 2 → humidity gauge\n    { payload: data.led_state }    // output 3 → LED status text\n];",
