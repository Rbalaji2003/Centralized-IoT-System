    {
        "id": "6587dd8f5196bf6a",
        "type": "ui_template",
        "z": "ddbcc77b5a1c5a84",
        "group": "84283bf8b6a22e73",
        "name": "Robot Animation",
        "order": 7,
        "width": 0,
        "height": 0,
        "format": "<div style=\"position: relative; width: 300px; height: 50px; border: 1px solid #444;\">\n  <div id=\"robot\" style=\"position: absolute; width: 50px; height: 50px; background-color: red;\"></div>\n</div>\n<script>\n(function(scope) {\n    var pos = 0;\n    var step = 50;\n    var max = 250;\n    scope.$watch('msg.payload', function(payload) {\n        if(payload === \"STEP_FORWARD\"){\n            pos += step;\n            if(pos>max) pos=max;\n        } else if(payload === \"STEP_BACKWARD\"){\n            pos -= step;\n            if(pos<0) pos=0;\n        }\n        document.getElementById('robot').style.left = pos + 'px';\n    });\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": false,
        "templateScope": "local",
        "className": "",
        "x": 450,
        "y": 500,
        "wires": [
            []
        ]
